    "zod": "^3.23.0",
    "@sentry/node": "^8.0.0",
    "@opentelemetry/sdk-node": "^0.55.0"
  },
  "devDependencies": {
    "@corredor/config": "workspace:*",
    "@corredor/core": "workspace:*",
    "@corredor/db": "workspace:*",
    "@corredor/telemetry": "workspace:*",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
