{
  "extends": "@corredor/config/tsconfig/web.json",
  "compilerOptions": {
    "outDir": "dist",
    // rootDir omitted: tsc --noEmit type-checks cross-package imports from workspace deps.
    // Vite handles bundling; rootDir restriction would block @corredor/api type inference.
    // React component prop patterns and @corredor/ui source imports conflict with
    // exactOptionalPropertyTypes. Disabled here; pure Node apps keep the strict setting.
    "exactOptionalPropertyTypes": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
