{
  "extends": "@corredor/config/tsconfig/nextjs.json",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "src",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".next"
  ],
  "compilerOptions": {
    "noEmit": true,
    "isolatedModules": true
  }
}
