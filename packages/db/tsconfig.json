{
  "extends": "@corredor/config/tsconfig/node.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    // Drizzle ORM internal types are not compatible with exactOptionalPropertyTypes.
    // Disabled here only; all other packages keep the strict setting.
    "exactOptionalPropertyTypes": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
