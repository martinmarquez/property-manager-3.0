# Neon Postgres — packages/db/.env
#
# SECURITY REQUIREMENT: Each developer must use their own personal Neon dev branch.
# NEVER put main-branch (production) credentials here.
# The main-branch credentials belong only in CI/CD secrets and production infrastructure.
#
# Setup (one-time, ~60 seconds):
#
#   1. Get your Neon API key: https://console.neon.tech/app/settings/api-keys
#   2. Get the project ID from your team lead or docs/runbooks/secrets.md
#   3. Run the setup script:
#
#      NEON_API_KEY=<your-key> NEON_PROJECT_ID=<project-id> \
#        ./infra/neon/dev-branch.sh <your-username>
#
#   4. Paste the output below (it replaces these placeholder values).
#
# The script creates a branch named "dev-<your-username>" in Neon (free, isolated copy
# of main). It auto-migrates from main and never touches production data.

# Neon Postgres connection string (pooled, for application use)
DATABASE_URL=postgresql://neondb_owner:REPLACE_ME@ep-REPLACE-ME-pooler.REGION.aws.neon.tech/neondb?channel_binding=require&sslmode=require

# Neon Postgres connection string (unpooled, for migrations and seed)
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:REPLACE_ME@ep-REPLACE-ME.REGION.aws.neon.tech/neondb?channel_binding=require&sslmode=require

# Test database — use same dev branch via unpooled endpoint (session vars survive across statements)
TEST_DATABASE_URL=postgresql://neondb_owner:REPLACE_ME@ep-REPLACE-ME.REGION.aws.neon.tech/neondb?channel_binding=require&sslmode=require
