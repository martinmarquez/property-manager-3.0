# Corredor CRM — Local development environment variables
#
# Copy this file to .env.local (already gitignored):
#   cp .env.example .env.local
#
# All values below match the defaults in docker-compose.yml.
# Override only the vars that differ on your machine.

# ---------------------------------------------------------------------------
# Node environment
# ---------------------------------------------------------------------------
NODE_ENV=development

# ---------------------------------------------------------------------------
# Postgres — matches docker-compose.yml postgres service
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://corredor:corredor@localhost:5432/corredor

# ---------------------------------------------------------------------------
# Redis — matches docker-compose.yml redis service
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Object storage (MinIO local / Cloudflare R2 in production)
# ---------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1        # MinIO ignores region; must match SDK default
S3_BUCKET_MEDIA=media
S3_BUCKET_DOCUMENTS=documents
S3_BUCKET_EXPORTS=exports
# Force path-style URLs (required for MinIO, not for R2)
S3_FORCE_PATH_STYLE=true

# ---------------------------------------------------------------------------
# Email — Mailhog SMTP (view emails at http://localhost:8025)
# ---------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@corredor.local

# ---------------------------------------------------------------------------
# API server
# ---------------------------------------------------------------------------
PORT=8080
API_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# Web app
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080
VITE_API_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# Authentication (replace with real secrets locally)
# ---------------------------------------------------------------------------
JWT_SECRET=dev-jwt-secret-change-in-production
SESSION_SECRET=dev-session-secret-change-in-production
COOKIE_DOMAIN=localhost

# ---------------------------------------------------------------------------
# OpenTelemetry (Jaeger — only if running the observability profile)
# docker compose --profile observability up -d
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=corredor-api

# ---------------------------------------------------------------------------
# Sentry (optional for local dev — events dropped when DSN is empty)
# ---------------------------------------------------------------------------
# SENTRY_DSN=https://....ingest.sentry.io/...
# SENTRY_RELEASE=0.1.0
# VITE_SENTRY_DSN=https://....ingest.sentry.io/...
# VITE_SENTRY_RELEASE=0.1.0

# ---------------------------------------------------------------------------
# PostHog (optional for local dev — events dropped when key is empty)
# ---------------------------------------------------------------------------
# VITE_POSTHOG_KEY=phc_...
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# ---------------------------------------------------------------------------
# AI providers (optional for local dev — set real keys to test AI features)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-proj-...       # text-embedding-3-small (RAG ingest), gpt-4.1-mini (fallback)
# ANTHROPIC_API_KEY=sk-ant-...     # claude-sonnet-4-6 (copilot), claude-haiku-4-5 (property AI)
# COHERE_API_KEY=...               # rerank-english-v3.0 (RAG rerank); omit to use Haiku fallback

# ---------------------------------------------------------------------------
# Cloudflare R2 — document storage (corredor-documents-{prod,staging})
# Production/staging: use R2 API token scoped to corredor-documents-* buckets.
# Local dev: MinIO via S3_* vars above; leave these blank.
# ---------------------------------------------------------------------------
# CLOUDFLARE_ACCOUNT_ID=abc123
# CLOUDFLARE_API_TOKEN=<r2-write-token>    # used by setup-r2-buckets.sh only
# R2_ACCESS_KEY_ID=<r2-access-key>
# R2_SECRET_ACCESS_KEY=<r2-secret-key>

# ---------------------------------------------------------------------------
# Signaturit e-sign — sandbox (https://app.signaturit.com → Account → API)
# ---------------------------------------------------------------------------
# SIGNATURIT_API_KEY=<sandbox-api-key>
# SIGNATURIT_API_BASE_URL=https://api.sandbox.signaturit.com

# ---------------------------------------------------------------------------
# DocuSign e-sign — developer sandbox (https://developers.docusign.com)
# Create an app in the demo environment to get these values.
# ---------------------------------------------------------------------------
# DOCUSIGN_INTEGRATION_KEY=<integration-key-uuid>
# DOCUSIGN_CLIENT_SECRET=<client-secret>
# DOCUSIGN_ACCOUNT_ID=<demo-account-id>
# DOCUSIGN_BASE_URL=https://demo.docusign.net

# ---------------------------------------------------------------------------
# Stripe billing — Phase G (https://dashboard.stripe.com → Developers → API keys)
# Use test mode keys locally (sk_test_... / pk_test_...).
# ---------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...       # Stripe dashboard → Webhooks → signing secret
# STRIPE_PRICE_ID_STARTER=price_...    # Starter plan price ID
# STRIPE_PRICE_ID_PRO=price_...        # Pro plan price ID
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ---------------------------------------------------------------------------
# Mercado Pago — AR domestic billing, Phase G (developers.mercadopago.com)
# Use sandbox credentials locally (TEST-...).
# ---------------------------------------------------------------------------
# MP_ACCESS_TOKEN=TEST-...             # Sandbox access token
# MP_PUBLIC_KEY=TEST-...               # Sandbox public key
# MP_WEBHOOK_SECRET=...                # MP webhook signing secret

# ---------------------------------------------------------------------------
# AFIP WSAA — electronic invoicing, Phase G
# See infra/afip/README.md for certificate generation instructions.
# ---------------------------------------------------------------------------
# AFIP_CUIT=20111111112                # Company CUIT (use 20111111112 for sandbox)
# AFIP_PRIVATE_KEY=<base64-encoded>    # base64 -i afip-wsaa-sandbox.key | tr -d '\n'
# AFIP_CERTIFICATE=<base64-encoded>    # base64 -i afip-wsaa-sandbox.crt | tr -d '\n'
# AFIP_SANDBOX=true

# ---------------------------------------------------------------------------
# Cloudflare — custom domain API for tenant websites, Phase G
# Same token as R2 above if scoped to account; or create a separate Pages token.
# ---------------------------------------------------------------------------
# CLOUDFLARE_ZONE_ID=<zone-id>         # Zone ID for the base domain (e.g. corredor.ar)

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
LOG_LEVEL=debug
