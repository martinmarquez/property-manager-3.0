{
  "name": "corredor",
  "version": "0.1.0",
  "private": true,
  "description": "Corredor — multi-tenant Argentine real estate CRM SaaS",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@corredor/config": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "overrides": {
      "tar": "^7.5.11",
      "serialize-javascript": "^7.0.3"
    }
  },
  "dependencies": {
    "@types/exceljs": "^1.3.2",
    "exceljs": "^4.4.0"
  }
}
